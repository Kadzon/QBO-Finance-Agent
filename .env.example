# qbagent configuration — copy to .env and fill in.
# All values are environment variables; .env is loaded automatically.

# ---------------------------------------------------------------------------
# LLM (required for `ask` / `chat`)
# ---------------------------------------------------------------------------
# LiteLLM model string. Examples:
#   anthropic/claude-opus-4-7
#   openai/gpt-4o
#   azure/my-deployment
QBAGENT_LLM_MODEL=anthropic/claude-opus-4-7
QBAGENT_LLM_API_KEY=sk-...
# QBAGENT_LLM_API_BASE=
# QBAGENT_LLM_TEMPERATURE=0.0
# QBAGENT_LLM_MAX_TOKENS=2048
# QBAGENT_LLM_REQUEST_TIMEOUT=60
# QBAGENT_LLM_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# Database backend
# ---------------------------------------------------------------------------
# One of: duckdb (default, zero-setup), sqlite, postgres.
QBAGENT_BACKEND=duckdb
# duckdb / sqlite:
QBAGENT_DB_PATH=./qbagent.duckdb
# postgres:
# QBAGENT_DB_URL=postgresql://user:pass@localhost:5432/qbagent

# ---------------------------------------------------------------------------
# QuickBooks Online via MCP (required for `sync`)
# ---------------------------------------------------------------------------
# Command that launches the MCP server. Example using Intuit's server:
#   QBAGENT_MCP_SERVER_COMMAND=npx
#   QBAGENT_MCP_SERVER_ARGS=-y @intuit/mcp-server-quickbooks
QBAGENT_MCP_SERVER_COMMAND=
QBAGENT_MCP_SERVER_ARGS=
# QBAGENT_MCP_SERVER_CWD=

# QBO developer-app credentials — forwarded to the MCP server's env.
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REALM_ID=
QUICKBOOKS_REFRESH_TOKEN=
QUICKBOOKS_ENVIRONMENT=sandbox

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------
QBAGENT_LOG_LEVEL=INFO
QBAGENT_LOG_FORMAT=console
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=qbagent

# ---------------------------------------------------------------------------
# Agent tuning (optional)
# ---------------------------------------------------------------------------
# QBAGENT_MAX_GENERATE_ATTEMPTS=3
# QBAGENT_QUERY_ROW_CAP=10000
